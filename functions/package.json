{
  "name": "@village/functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:rules": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=test/rules --testPathIgnorePatterns=/node_modules/",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules firebase emulators:exec --only firestore,auth \"jest\"",
    "emulators": "firebase emulators:start --only functions,firestore,auth",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "shell": "pnpm build && firebase functions:shell",
    "start": "pnpm shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@village/shared": "workspace:*",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "cross-env": "^10.1.0",
    "firebase": "^11.10.0",
    "firebase-functions-test": "^3.5.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.2"
  }
}
